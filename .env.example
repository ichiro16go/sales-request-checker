JIRA_BASE_URL=https://epark-tech.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token-here
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5.2
WEBHOOK_SHARED_SECRET=change-me
ALLOWED_PROJECT_KEYS=JPREQ

# WSL/headless Linux で forge deploy 時に keytar エラーが出る場合に設定する
# FORGE_EMAIL と FORGE_API_TOKEN を設定すると keytar を使わずに認証できる
# FORGE_API_TOKEN は https://id.atlassian.com/manage-profile/security/api-tokens で発行
FORGE_EMAIL=your-email@example.com
FORGE_API_TOKEN=your-atlassian-api-token
